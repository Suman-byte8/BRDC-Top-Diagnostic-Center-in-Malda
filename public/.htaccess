<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Redirect to trailing slash for directories
  # If the request doesn't have a trailing slash and is not a file
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !(.*)/$
  RewriteRule ^(.*)$ $1/ [L,R=301]

  # 2. Handle subdirectories with index.html (Next.js trailingSlash: true export)
  # Apache automatically serves index.html if DirectoryIndex is set.

  # 3. Fallback for SPA routing or missing files to index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^.*$ /index.html [L,QSA]
</IfModule>
